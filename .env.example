APP_NAME=LotoIA
APP_ENV=development
LOG_LEVEL=INFO
DATA_DIR=data
API_HOST=127.0.0.1
API_PORT=8000

# Evolution API (WhatsApp outbound)
EVOLUTION_API_URL=https://evolution.lotoia.up.railway.app
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=your_instance_name

# Facebook Messenger (Evolution API + Meta webhook)
EVOLUTION_MESSENGER_INSTANCE=your_messenger_instance_name
MESSENGER_VERIFY_TOKEN=your_messenger_verify_token
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# Asaas webhook (ativação automática após PIX)
ASAAS_WEBHOOK_TOKEN=your_asaas_webhook_auth_token
# Opcional: buscar nome do cliente no Asaas ao ativar
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
