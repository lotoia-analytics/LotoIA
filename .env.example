APP_NAME=LotoIA
APP_ENV=development
LOG_LEVEL=INFO
DATA_DIR=data
API_HOST=127.0.0.1
API_PORT=8000

# Railway / PostgreSQL (Lei No 001 — fonte única em produção)
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# LOTOIA_DATABASE_URL=
# STREAMLIT_DATABASE_URL=
# LOTOIA_DATABASE_POOLER_URL=
# STREAMLIT_DATABASE_POOLER_URL=
# LOTOIA_SUPABASE_PROJECT_REF=
# LOTOIA_SUPABASE_POOLER_HOST=aws-1-us-west-1.pooler.supabase.com
# LOTOIA_DATABASE_CONNECT_TIMEOUT_SECONDS=30
# LOTOIA_DATABASE_POOL_SIZE=1
# LOTOIA_DATABASE_MAX_OVERFLOW=0

# Cloud-only runtime (Railway)
# LOTOIA_CLOUD_ONLY=1
# LOTOIA_AUTH_REQUIRED=1
# LOTOIA_ADMIN_EMAIL=admin@lotoia.chat
# LOTOIA_ADMIN_PASSWORD=change_me_in_railway_secrets
# Cliente pg_dump — PostgreSQL 10 no Railway (ajuste se upgrade do Postgres)
# LOTOIA_POSTGRESQL_CLIENT_MAJOR=10

# Evolution API (WhatsApp outbound)
EVOLUTION_API_URL=https://evolution.lotoia.up.railway.app
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=your_instance_name

# Facebook Messenger (Meta Graph API outbound + webhook inbound)
MESSENGER_VERIFY_TOKEN=your_messenger_verify_token
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
# Opcional: Evolution 2.3.x não suporta Messenger; use só se sua Evolution tiver canal Facebook
EVOLUTION_MESSENGER_INSTANCE=your_messenger_instance_name

# Asaas webhook (ativação automática após PIX)
ASAAS_WEBHOOK_TOKEN=your_asaas_webhook_auth_token
# Opcional: buscar nome do cliente no Asaas ao ativar
ASAAS_API_KEY=
ASAAS_API_URL=https://api.asaas.com/v3
