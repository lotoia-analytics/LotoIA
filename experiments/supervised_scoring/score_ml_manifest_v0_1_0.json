  "adr_references": [
    "ADR_001_PARADIGMA_HIBRIDO",
    "ADR_002_NAMESPACE_OFICIAL",
    "ADR_003_IMPORT_RESOLUTION",
    "ADR_004_RERANK_CONSOLIDATION",
    "ADR_005_TEMPORAL_GOVERNANCE",
    "ADR_006_TEMPORAL_BENCHMARK",
    "ADR_007_SUPERVISED_DATASET_GOVERNANCE",
    "ADR_008_INCREMENTAL_SCORE_ML"
  ],
  "model": {
    "model_id": "score-ml-linear-baseline-v0-1-0",
    "model_version": "score-ml-linear-baseline-v0.1.0",
    "model_family": "interpretable_linear_baseline",
    "role": "auxiliary_incremental_rerank",
    "replaces_statistical_ranking": false
  },
  "feature_schema": {
    "feature_schema_version": "score-ml-features-v0.1.0",
    "features": [
      "final_score_norm",
      "quadra_density",
      "sum_balance",
      "odd_balance",
      "center_balance",
      "frame_balance"
    ],
    "temporal_policy": "candidate_static_or_precomputed_before_scoring"
  },
  "attribution": {
    "required": true,
    "method": "linear_feature_contribution",
    "output_field": "score_ml_details.attribution"
