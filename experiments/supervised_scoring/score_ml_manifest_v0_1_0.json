  "temporal_validation": {
    "walk_forward_required": true,
    "temporal_split": {
      "split_id": "wf_score_ml_baseline_001",
      "train_start": 1,
      "train_end": 2000,
      "test_start": 2001,
      "test_end": 2010
    },
    "required_relation": "feature_cutoff_contest < scoring_contest"
  },
  "benchmark_comparability": {
    "benchmark_required": true,
    "benchmark_reference": "experiments/temporal_benchmark/manifests/temporal_baseline_v0_1_0.json",
    "statistical_benchmark_replaced": false,
    "comparison_role": "auxiliary_rerank_delta"
  },
  "reproducibility": {
    "model_version": "score-ml-linear-baseline-v0.1.0",
    "feature_schema_version": "score-ml-features-v0.1.0",
    "random_seed_policy": "deterministic_no_random_training_in_default_baseline"
  },
  "operational_constraints": {
    "no_deep_learning": true,
    "no_automl": true,
    "no_opaque_models": true,
    "no_temporal_leakage": true
  }
