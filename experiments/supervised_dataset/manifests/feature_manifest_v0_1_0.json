{
  "manifest_id": "feature-manifest-v0.1.0",
  "schema_version": "feature-manifest-schema-v0.1.0",
  "dataset_version": "lotofacil-supervised-governance-v0.1.0-2026-05-16",
  "created_at": "2026-05-16T00:00:00-03:00",
  "adr_references": [
    "ADR_001_PARADIGMA_HIBRIDO",
    "ADR_002_NAMESPACE_OFICIAL",
    "ADR_003_IMPORT_RESOLUTION",
    "ADR_004_RERANK_CONSOLIDATION",
    "ADR_005_TEMPORAL_GOVERNANCE",
    "ADR_006_TEMPORAL_BENCHMARK",
    "ADR_007_SUPERVISED_DATASET_GOVERNANCE"
  ],
  "feature_schema_version": "supervised-features-v0.1.0",
  "features": [
    {
      "name": "frequency_score_at_cutoff",
      "dtype": "float",
      "source": "lotoia.statistics.temporal.frequency_component",
      "temporal_scope": "historical_before_cutoff",
      "uses_label_contest": false,
      "description": "Frequency component computed only from history before feature_cutoff_contest."
    },
    {
      "name": "delay_score_at_cutoff",
      "dtype": "float",
      "source": "lotoia.statistics.temporal.delay_component",
      "temporal_scope": "historical_before_cutoff",
      "uses_label_contest": false,
      "description": "Delay component computed only from history before feature_cutoff_contest."
    },
    {
      "name": "candidate_sum_score",
      "dtype": "float",
      "source": "lotoia.statistics.temporal.sum_component",
      "temporal_scope": "candidate_static",
      "uses_label_contest": false,
      "description": "Candidate structural sum score without access to future contests."
    }
  ],
  "temporal_policy": {
    "requires_feature_cutoff_contest": true,
    "feature_window": "strictly_before_label_contest",
    "history_rule": "all historical aggregations must use contests lower than feature_cutoff_contest"
  },
  "prohibitions": {
    "future_contest_statistics": true,
    "label_derived_features": true,
    "global_full_history_statistics": true,
    "score_ml": true
  }
}
