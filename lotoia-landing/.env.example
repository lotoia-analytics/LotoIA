# Backend FastAPI (WhatsApp + webhook Asaas)
NEXT_PUBLIC_API_URL=https://intuitive-gratitude-production.up.railway.app
# Configure no painel Asaas: POST {NEXT_PUBLIC_API_URL}/asaas/webhook

# Asaas PIX (obrigatório em produção)
ASAAS_API_KEY=
# Produção: https://api.asaas.com/v3 | Sandbox: https://api-sandbox.asaas.com/v3
ASAAS_API_URL=https://api.asaas.com/v3

# Dados institucionais (páginas legais / anúncios)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=LotoIA
NEXT_PUBLIC_COMPANY_CNPJ=
